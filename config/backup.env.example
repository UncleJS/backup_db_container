# =============================================================================
# backup.env.example
#
# Copy to backup.env and fill in your values.
# Used by: backup-agent.container (Quadlet Environment= lines mirror these).
# NEVER commit a filled-in backup.env to version control.
#
# Secrets (passwords, keys) must be stored as Podman secrets, NOT here.
# See secrets/SECRETS.md for how to create them.
# =============================================================================

# ---------------------------------------------------------------------------
# Backup agent
# ---------------------------------------------------------------------------
BACKUP_DIR=/backups
MARIADB_BACKUP_MODE=full          # full | incremental
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_BACKUP_USER=root
BACKUP_TARGET_LABEL=production    # human label for this host in tracking DB
RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Tracking database connection (used by API + agent)
# ---------------------------------------------------------------------------
TRACKING_DB_HOST=localhost
TRACKING_DB_PORT=3306
TRACKING_DB_NAME=backup_tracking
TRACKING_DB_USER=backup_api
# TRACKING_DB_PASSWORD → Podman secret: tracking_db_password

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
PORT=3001
NODE_ENV=production

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
# PORT=3000  (set inside Quadlet unit)
API_INTERNAL_URL=http://localhost:3001   # pod-internal URL for SSR calls
# SESSION_SECRET            → Podman secret: dashboard_session_secret
# ADMIN_PASSWORD            → Podman secret: dashboard_admin_password
# INTERNAL_API_SECRET       → Podman secret: internal_api_secret

# ---------------------------------------------------------------------------
# S3 / rclone (non-secret parts)
# ---------------------------------------------------------------------------
RCLONE_CONFIG_S3BACKUPTOOL_TYPE=s3
RCLONE_CONFIG_S3BACKUPTOOL_PROVIDER=Other   # Other = generic S3-compat; use AWS for AWS
RCLONE_CONFIG_S3BACKUPTOOL_ENV_AUTH=false
RCLONE_CONFIG_S3BACKUPTOOL_ENDPOINT=https://s3.amazonaws.com
RCLONE_CONFIG_S3BACKUPTOOL_REGION=us-east-1
RCLONE_CONFIG_S3BACKUPTOOL_ACCESS_KEY_ID=CHANGE_ME
S3_BUCKET=my-backups-bucket
S3_PATH_PREFIX=backups/
# S3 secret key → Podman secret: s3_secret_key

# ---------------------------------------------------------------------------
# SFTP / rclone (non-secret parts)
# ---------------------------------------------------------------------------
RCLONE_CONFIG_SFTPTOOL_TYPE=sftp
RCLONE_CONFIG_SFTPTOOL_HOST=sftp.example.com
RCLONE_CONFIG_SFTPTOOL_PORT=22
RCLONE_CONFIG_SFTPTOOL_USER=backup-user
SFTP_PATH=/backups/
# SFTP password → Podman secret: sftp_password
# SFTP private key (PEM) → Podman secret: sftp_private_key
