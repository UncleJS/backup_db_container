# =============================================================================
# backup-agent.service  — Quadlet service unit (manual / timer-activated)
# Place in: ~/.config/containers/systemd/
#
# This service is started by backup-agent.timer OR manually via:
#   systemctl --user start backup-agent.service
#
# NOTE: Quadlet generates a systemd service named "backup-agent.service" from
# backup-agent.container.  This wrapper simply delegates to that generated unit.
# The generated name is always "<stem>.service" — never "<stem>-container.service".
# =============================================================================
[Unit]
Description=Backup Agent Run
After=backup-pod.service backup-api.service backup-tracking-db.service
Requires=backup-pod.service backup-api.service backup-tracking-db.service

[Service]
Type=oneshot
# Delegate to the Quadlet-generated container unit (stem = "backup-agent")
ExecStart=systemctl --user start backup-agent.service
RemainAfterExit=no

[Install]
WantedBy=default.target
